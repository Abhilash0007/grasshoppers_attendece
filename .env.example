# Database
MONGODB_URI=mongodb://localhost:27017/grasshoppers-punch
# or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/grasshoppers-punch

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Next Auth
NEXTAUTH_SECRET=your_nextauth_secret_key_change_this_in_production
NEXTAUTH_URL=http://localhost:3000

# Email (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@grasshoppers.com
EMAIL_FROM_NAME=Grasshoppers Team

# Push Notifications (Web Push)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@grasshoppers.com

# App Config
NEXT_PUBLIC_APP_NAME=Grasshoppers Punch Attendance
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Admin Email
ADMIN_EMAIL=admin@grasshoppers.com

# Feature Flags
ENABLE_GEOLOCATION=true
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL=true
OFFLINE_MODE_ENABLED=true
